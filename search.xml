      <title>实习整理</title>
      <link href="/2026/03/10/%E5%AE%9E%E4%B9%A0%E6%95%B4%E7%90%86/"/>
      <url>/2026/03/10/%E5%AE%9E%E4%B9%A0%E6%95%B4%E7%90%86/</url>
      
        <content type="html"><![CDATA[<div id="hexo-blog-encrypt" data-wpm="密码错误，请重试！" data-whm="密码验证失败！">  <div class="hbe-input-container">  <input type="password" id="hbePass" placeholder="请输入文章加密密码" />    <label>请输入文章加密密码</label>    <div class="bottom-line"></div>  </div>  <script id="hbeData" type="hbeData" data-hmacdigest="ad3ffafc7b2ef5c9f85bd0fa968d6bcb43a28cbb69ad3c1e12dbe4e3b9875f01">9ef2a3e635f3dc7e309ca51f1b1beec7c8fa410d0b9d0c79d83ccfe2e30df7cde436f1816ae2c586435b99cb61f28a4c26901266941ad9331f8794f23db4493a4f14411e66df7b50dffaedd3dbf41d8c</script></div><!-- 保留插件原有解密逻辑，仅修改提示语相关 --><script>  (function (window, document) {    'use strict';    var hexoBlogEncrypt = window.hexoBlogEncrypt = {      decrypt: function () {        var pass = document.getElementById('hbePass').value;        var encryptedData = document.getElementById('hbeData').textContent;        var hmacDigest = document.getElementById('hbeData').dataset.hmacdigest;        if (!encryptedData || !hmacDigest) {          console.error('No encrypted data found');          return;        }        try {          var decrypted = CryptoJS.AES.decrypt(encryptedData, pass);          decrypted = decrypted.toString(CryptoJS.enc.Utf8);          if (CryptoJS.SHA256(decrypted).toString() === hmacDigest) {            document.getElementById('hexo-blog-encrypt').innerHTML = decrypted;          }         } catch (e) {                  }      }    };    // 绑定回车事件    document.getElementById('hbePass').addEventListener('keydown', function (e) {      if (e.key === 'Enter') {        hexoBlogEncrypt.decrypt();      }    });  })(window, document);</script><script src="/lib/blog-encrypt.js"></script><link href="/css/blog-encrypt.css" rel="stylesheet" type="text/css">]]></content>
      
      
